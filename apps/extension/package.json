{
    "name": "@viewportvr/extension",
    "displayName": "ViewportVR",
    "version": "0.0.1",
    "description": "The hyperspace navigator.",
    "author": "obfuscatedgenerated",
    "scripts": {
        "dev": "plasmo dev",
        "build": "plasmo build",
        "package": "plasmo package",
        "build-schema": "tsx scripts/build_json_schema.ts"
    },
    "//": "note the hard coded react versions. plasmo cannot read catalog: react version, so will need to manually sync",
    "dependencies": {
        "@viewportvr/ui-dom": "workspace:*",
        "@viewportvr/vr-engine": "workspace:*",
        "@viewportvr/platform-extension": "workspace:*",
        "@viewportvr/watch-ui": "workspace:*",
        "@viewportvr/auth": "workspace:*",
        "@plasmohq/messaging": "^0.7.2",
        "@plasmohq/storage": "^1.15.0",
        "@react-three/xr": "catalog:",
        "@react-three/drei": "catalog:",
        "@react-three/uikit": "catalog:",
        "@react-three/uikit-default": "catalog:",
        "lucide-react": "catalog:",
        "plasmo": "0.90.5",
        "react": "18.2.0",
        "react-dom": "18.2.0",
        "three": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "catalog:",
        "@types/chrome": "catalog:",
        "@types/node": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "@types/three": "catalog:",
        "tailwindcss": "catalog:",
        "postcss-preset-mantine": "^1.18.0",
        "postcss-simple-vars": "^7.0.1",
        "tailwind-preset-mantine": "^4.1.0"
    },
    "manifest": {
        "host_permissions": [
            "https://*/*"
        ],
        "permissions": [
            "contextMenus",
            "tabCapture",
            "activeTab",
            "offscreen",
            "debugger"
        ],
        "content_security_policy": {
            "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
        }
    }
}
