{
    "extends": ["../../tsconfig.base.json", "./.wxt/tsconfig.json"],
    "exclude": ["node_modules"],
    "include": ["src/**/*", ".wxt/types/**/*.d.ts", "wxt.config.ts"],
    "compilerOptions": {
        "paths": {
            "~*": ["src/*"],
            "@viewportvr/asset-resolver": [
                "../../packages/asset-resolver/asset-resolver.d.ts"
            ]
        },
        "baseUrl": ".",
        "composite": false,
        "resolveJsonModule": true
    }
}
