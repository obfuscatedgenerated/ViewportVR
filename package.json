{
    "name": "viewportvr",
    "license": "AGPL-3.0-only",
    "private": true,
    "packageManager": "pnpm@10.19.0",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "build:extension": "cd apps/extension && pnpm build",
        "build:schema": "tsx scripts/build_json_schema.ts",
