    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.1.1",
        "autoprefixer": "^10.5.0",
        "knip": "^6.20.0",
        "prettier": "3.2.4",
        "tsx": "^4.22.4",
        "turbo": "latest",
        "typescript": "5.9.3"
    }
}
