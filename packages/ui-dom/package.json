{
    "name": "@hyperlinkvr/ui-dom",
    "version": "0.0.1",
    "private": true,
    "main": "src/index.tsx",
    "types": "src/index.tsx",
    "exports": {
        ".": {
            "import": "./src/index.tsx",
            "require": "./src/index.tsx",
            "types": "./src/index.tsx"
        },
        "./*": {
            "import": "./src/*/index.ts",
            "require": "./src/*/index.ts",
            "types": "./src/*/index.ts"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@hyperlinkvr/auth": "workspace:*",
        "@hyperlinkvr/react": "workspace:*",
        "@hyperlinkvr/types": "workspace:*",
        "react": "catalog:",
        "lucide-react": "catalog:"
    },
    "devDependencies": {
        "@types/react": "catalog:"
    }
}
