{
    "name": "@hyperlinkvr/vr-engine",
    "version": "0.0.1",
    "private": true,
    "main": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "require": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./*": {
            "import": "./src/*/index.ts",
            "require": "./src/*/index.ts",
            "types": "./src/*/index.ts"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@react-three/drei": "catalog:",
        "@react-three/fiber": "catalog:",
        "@react-three/uikit": "^1.0.74",
        "@react-three/uikit-default": "^1.0.74",
        "@react-three/xr": "catalog:",
        "@react-three/handle": "catalog:",
        "@hyperlinkvr/react": "workspace:*",
        "@hyperlinkvr/watch-ui": "workspace:*",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-error-boundary": "^6.1.2",
        "three": "catalog:",
        "troika-three-text": "catalog:"
    },
    "devDependencies": {
        "@types/react": "catalog:",
        "@types/three": "catalog:",
        "@types/troika-three-text": "workspace:*"
    }
}
